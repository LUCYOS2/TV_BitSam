<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="17.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{3A42BDF2-0A15-4188-AD79-184FE2855F9B}</ProjectGuid>
    <RootNamespace>Core</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>StaticLibrary</ConfigurationType>
    <!-- v143 = VS2022, the toolset most commonly paired with NX2406 at the
         time of writing. If the office PC has a different VS version
         installed, Visual Studio will offer to "Retarget Solution" the
         first time this is opened there - accept it, don't hand-edit this
         value speculatively. (Leaving this unset instead of pinning it
         falls back to the ancient v100 toolset, which is worse.) -->
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <!-- Core has ZERO dependency on NXOpen - this project must build with
         a plain MSVC/Build Tools install, no NX installation required. -->
    <OutDir>$(SolutionDir)build\$(Configuration)\$(Platform)\</OutDir>
    <IntDir>$(SolutionDir)build\obj\$(ProjectName)\$(Configuration)\$(Platform)\</IntDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <AdditionalIncludeDirectories>$(ProjectDir)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <ConformanceMode>true</ConformanceMode>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClInclude Include="include\Core\Models\BoundingBox3D.h" />
    <ClInclude Include="include\Core\Models\SessionInfo.h" />
    <ClInclude Include="include\Core\Models\ComponentInfo.h" />
    <ClInclude Include="include\Core\Models\GeometryInfo.h" />
    <ClInclude Include="include\Core\Models\MaterialInfo.h" />
    <ClInclude Include="include\Core\Models\ROISelection.h" />
    <ClInclude Include="include\Core\Models\OperationResult.h" />
    <ClInclude Include="include\Core\Interfaces\ILogger.h" />
    <ClInclude Include="include\Core\Interfaces\INxSessionProvider.h" />
    <ClInclude Include="include\Core\Interfaces\IAssemblyReader.h" />
    <ClInclude Include="include\Core\Interfaces\IGeometryReader.h" />
    <ClInclude Include="include\Core\Interfaces\IMaterialReader.h" />
    <ClInclude Include="include\Core\Interfaces\IROIManager.h" />
    <ClInclude Include="include\Core\Interfaces\IRoiResolver.h" />
    <ClInclude Include="include\Core\Logging\ConsoleLogger.h" />
    <ClInclude Include="include\Core\ROI\ROIManager.h" />
    <ClInclude Include="include\Core\Export\JsonWriter.h" />
    <ClInclude Include="include\Core\Export\JsonSceneExporter.h" />
  </ItemGroup>

  <ItemGroup>
    <ClCompile Include="src\ConsoleLogger.cpp" />
    <ClCompile Include="src\ROIManager.cpp" />
    <ClCompile Include="src\JsonWriter.cpp" />
    <ClCompile Include="src\JsonSceneExporter.cpp" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
